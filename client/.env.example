# Copy this file to .env and adjust values for your environment.
# .env is gitignored — never commit real values.

VITE_GRAPHQL_URL=http://localhost:4000/graphql
VITE_WS_URL=ws://localhost:4000/graphql/ws

# Must match the server API_KEY value. Sent in the graphql-ws connectionParams
# as 'Bearer <key>' during the connection_init handshake.
VITE_WS_API_KEY=SECRET_KEY_GOES_HERE
