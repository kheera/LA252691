# Copy this file to .env and fill in values before running docker compose.
# .env is never committed to source control.

# ── Server ───────────────────────────────────────────────────────────────────
# Port the GraphQL API listens on inside the container (and exposed on the host)
PORT=4000

# Allowed CORS origin — should match the public URL of the client
CORS_ORIGIN=http://localhost:3000

# Disable GraphQL introspection (true = disabled). Should be true in production.
# Set to false only for local development/tooling that needs schema discovery.
DISABLE_INTROSPECTION=true

# API key required by WebSocket clients in connectionParams.authorization.
# Format sent by client: "Bearer <key>".
API_KEY=SECRET_KEY_GOES_HERE

# ── Client (Vite build-time) ──────────────────────────────────────────────────
# Full URL to the GraphQL HTTP endpoint, as seen by the *browser*.
# For local Docker Compose this is always the host-mapped server port.
VITE_GRAPHQL_URL=http://localhost:4000/graphql

# WebSocket endpoint for GraphQL subscriptions.
VITE_WS_URL=ws://localhost:4000/graphql/ws

# Must match the server API_KEY value above. Sent in graphql-ws connectionParams
# as 'Bearer <key>' during the connection_init handshake.
VITE_WS_API_KEY=SECRET_KEY_GOES_HERE
